# ─── FinTrack CRM — Variables d'environnement ────────────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs.
# Sur Dokploy : collez ces variables dans l'onglet "Environment" du service.
# ─────────────────────────────────────────────────────────────────────────────

DJANGO_SETTINGS_MODULE=config.settings.production

# Django
SECRET_KEY=changez-moi-en-production-minimum-50-caracteres-aleatoires
DEBUG=False
ALLOWED_HOSTS=votre-domaine.com,www.votre-domaine.com

# CSRF — obligatoire Django 4+ (Traefik/HTTPS)
CSRF_TRUSTED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# Base de données MariaDB
DB_NAME=fintrack_db
DB_USER=fintrack
DB_PASSWORD=mot-de-passe-fort
DB_ROOT_PASSWORD=mot-de-passe-root-fort
DB_HOST=db
DB_PORT=3306

# Redis & Celery
REDIS_URL=redis://redis:6379/0

# Email (optionnel)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@email.com
EMAIL_HOST_PASSWORD=votre-mot-de-passe-app
DEFAULT_FROM_EMAIL=noreply@votre-domaine.com
